<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="UTF-8">

    <title>Dashboard</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

</head>

<body class="bg-light">

<div class="container py-5">

    <h1 class="mb-5">
        Dashboard
    </h1>

    <div class="row">

        <div class="col-md-4">

            <div class="card p-4 mb-4">

                <h3>
                    Confirmados
                </h3>

                <h1>
                    <%= confirmed %>
                </h1>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card p-4 mb-4">

                <h3>
                    Rechazados
                </h3>

                <h1>
                    <%= declined %>
                </h1>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card p-4 mb-4">

                <h3>
                    Asistentes
                </h3>

                <h1>
                    <%= attendees %>
                </h1>

            </div>

        </div>

    </div>

    <div class="card p-4">

        <h3 class="mb-4">
            Últimas respuestas
        </h3>

        <table class="table">

            <thead>

            <tr>

                <th>Nombre</th>
                <th>Estado</th>
                <th>Personas</th>

            </tr>

            </thead>

            <tbody>

            <% latestRsvps.forEach(rsvp => { %>

                <tr>

                    <td>
                        <%= rsvp.reservation_name %>
                    </td>

                    <td>
                        <%= rsvp.status %>
                    </td>

                    <td>
                        <%= rsvp.attendees_count %>
                    </td>

                </tr>

            <% }) %>

            </tbody>

        </table>

    </div>

</div>

</body>
</html>