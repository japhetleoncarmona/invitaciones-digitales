<div class="card mb-4">
    <div class="card-body">
        <h4 class="mb-3">Agregar actividad</h4>

        <form action="/admin/events/<%= event.id %>/timeline" method="POST">
            <div class="row">
                <div class="col-md-2 mb-3">
                    <input
                        type="text"
                        name="hour"
                        class="form-control"
                        placeholder="18:00"
                        required
                    >
                </div>

                <div class="col-md-4 mb-3">
                    <input
                        type="text"
                        name="title"
                        class="form-control"
                        placeholder="Recepción"
                        required
                    >
                </div>

                <div class="col-md-4 mb-3">
                    <input
                        type="text"
                        name="description"
                        class="form-control"
                        placeholder="Descripción opcional"
                    >
                </div>

                <div class="col-md-2 mb-3">
                    <input
                        type="number"
                        name="order"
                        class="form-control"
                        placeholder="Orden"
                        value="0"
                    >
                </div>
            </div>

            <button class="btn btn-primary">
                Guardar actividad
            </button>
        </form>
    </div>
</div>