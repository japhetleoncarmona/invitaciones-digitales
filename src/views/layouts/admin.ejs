<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Admin - Invitaciones Digitales</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f5f5f7;
        }

        .sidebar {
            min-height: 100vh;
            background: #111827;
            color: white;
            padding: 30px 20px;
        }

        .sidebar a {
            color: #d1d5db;
            text-decoration: none;
            display: block;
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 8px;
        }

        .sidebar a:hover {
            background: #1f2937;
            color: white;
        }

        .content {
            padding: 40px;
        }

        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,.05);
        }
    </style>
</head>
<body>

<div class="d-flex">
    <aside class="sidebar" style="width:260px;">
        <h4 class="mb-4">Invitaciones</h4>

        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/events">Eventos</a>
        <a href="/evento/xv-maria" target="_blank">Ver invitación</a>
    </aside>

    <main class="content flex-grow-1">
        <%- body %>
    </main>
</div>

</body>
</html>